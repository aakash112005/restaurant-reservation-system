# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/restaurant_reservations

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - comma separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173

# Demo admin account - used ONLY by the seed script (npm run seed)
# Change these before running the seed script in any shared/production environment
ADMIN_NAME=Restaurant Owner
ADMIN_EMAIL=admin@thenightlytable.com
ADMIN_PASSWORD=Admin@12345

# Reservation business rules
RESERVATION_SLOT_MINUTES=90
MAX_ADVANCE_BOOKING_DAYS=60
